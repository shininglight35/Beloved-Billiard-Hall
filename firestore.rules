rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{doc} {
      allow read, write;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
